"use client";

import { useEffect, useMemo, useState } from "react";
import AppShell from "@/components/layout/AppShell";
import apiClient from "@/lib/apiClient";

type HealthResponse = {
  status: string;
  app: string;
  env: string;
  checks: Record<string, string>;
};

type Opportunity = {
  id: number;
  title: string;
  agency: string | null;
  portal: string;
  status: string | null;
  due_date: string | null;
  relevance_score: number;
};

export default function HomePage() {
  const [health, setHealth] = useState<HealthResponse | null>(null);
  const [items, setItems] = useState<Opportunity[]>([]);

  useEffect(() => {
    async function loadDashboard() {
      const healthRes = await apiClient.get("/health");
      const oppRes = await apiClient.get("/opportunities", {
        params: { page: 1, size: 100, sort: "id_desc" },
      });

      setHealth(healthRes.data);
      setItems(oppRes.data.items || []);
    }

    loadDashboard().catch((err) => {
      console.error("Dashboard load failed", err);
    });
  }, []);

  const stats = useMemo(() => {
    const open = items.filter((item) => item.status === "Accepting Bids").length;
    const portals = new Set(items.map((item) => item.portal)).size;
    const agencies = new Set(items.map((item) => item.agency).filter(Boolean)).size;

    return {
      total: items.length,
      open,
      portals,
      agencies,
    };
  }, [items]);

  return (
    <AppShell>
      <div className="space-y-6">
        <div>
          <h2 className="text-3xl font-semibold text-slate-900">
            Executive Dashboard
          </h2>
          <p className="text-sm text-slate-600 mt-1">
            Central view of active procurement opportunities and platform health.
          </p>
        </div>

        <div className="grid grid-cols-1 md:grid-cols-4 gap-4">
          <div className="bg-white rounded-xl border p-5 shadow-sm">
            <div className="text-sm text-slate-500">Loaded Opportunities</div>
            <div className="text-3xl font-semibold text-slate-900 mt-2">
              {stats.total}
            </div>
          </div>

          <div className="bg-white rounded-xl border p-5 shadow-sm">
            <div className="text-sm text-slate-500">Open Opportunities</div>
            <div className="text-3xl font-semibold text-emerald-700 mt-2">
              {stats.open}
            </div>
          </div>

          <div className="bg-white rounded-xl border p-5 shadow-sm">
            <div className="text-sm text-slate-500">Sources Covered</div>
            <div className="text-3xl font-semibold text-slate-900 mt-2">
              {stats.portals}
            </div>
          </div>

          <div className="bg-white rounded-xl border p-5 shadow-sm">
            <div className="text-sm text-slate-500">Agency Groups</div>
            <div className="text-3xl font-semibold text-slate-900 mt-2">
              {stats.agencies}
            </div>
          </div>
        </div>

        <div className="grid grid-cols-1 lg:grid-cols-3 gap-4">
          <div className="bg-white rounded-xl border p-5 shadow-sm lg:col-span-2">
            <h3 className="font-semibold text-slate-900 mb-4">
              Recent Opportunity Intake
            </h3>

            <div className="space-y-3">
              {items.slice(0, 6).map((item) => (
                <div key={item.id} className="flex justify-between border-b pb-3">
                  <div>
                    <div className="text-sm font-medium text-slate-900">
                      {item.title}
                    </div>
                    <div className="text-xs text-slate-500 mt-1">
                      {item.agency || "Agency not listed"} · {item.portal}
                    </div>
                  </div>
                  <span className="text-xs px-2 py-1 rounded bg-blue-50 text-blue-700 h-fit">
                    {item.status || "Pending"}
                  </span>
                </div>
              ))}
            </div>
          </div>

          <div className="bg-white rounded-xl border p-5 shadow-sm">
            <h3 className="font-semibold text-slate-900 mb-4">
              System Status
            </h3>

            {health ? (
              <div className="space-y-3 text-sm">
                <div className="flex justify-between">
                  <span className="text-slate-500">API</span>
                  <span className="font-medium text-emerald-700">{health.status}</span>
                </div>

                {Object.entries(health.checks).map(([key, value]) => (
                  <div key={key} className="flex justify-between">
                    <span className="text-slate-500 capitalize">{key}</span>
                    <span className="font-medium text-emerald-700">{value}</span>
                  </div>
                ))}
              </div>
            ) : (
              <p className="text-sm text-slate-500">Loading status...</p>
            )}
          </div>
        </div>
      </div>
    </AppShell>
  );
}
