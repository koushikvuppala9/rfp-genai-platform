"use client";

import { useEffect, useState } from "react";
import AppShell from "@/components/layout/AppShell";
import apiClient from "@/lib/apiClient";

export default function HomePage() {
  const [health, setHealth] = useState<unknown>(null);

  useEffect(() => {
    async function fetchHealth() {
      try {
        const res = await apiClient.get("/health");
        setHealth(res.data);
      } catch (err) {
        console.error("Health fetch failed", err);
      }
    }

    fetchHealth();
  }, []);

  return (
    <AppShell>
      <h2 className="text-2xl font-semibold mb-6">RFP GenAI Dashboard</h2>

      <div className="bg-white p-4 rounded shadow mb-6">
        <h3 className="text-lg font-medium mb-2">System Health</h3>

        {health ? (
          <pre className="text-sm">{JSON.stringify(health, null, 2)}</pre>
        ) : (
          <p>Loading...</p>
        )}
      </div>

      <div className="grid grid-cols-1 md:grid-cols-3 gap-4">
        <div className="bg-white p-4 rounded shadow">RFP Intelligence</div>
        <div className="bg-white p-4 rounded shadow">BI Dashboard</div>
        <div className="bg-white p-4 rounded shadow">Workflow Engine</div>
      </div>
    </AppShell>
  );
}