"use client";

import { useEffect, useState } from "react";
import AppShell from "@/components/layout/AppShell";
import apiClient from "@/lib/apiClient";

type Opportunity = {
  id: number;
  title: string;
  agency: string;
  portal: string;
  status: string;
  due_date: string;
  relevance_score: number;
  source_url: string;
  first_seen_at?: string;
  last_changed_at?: string;
};

export default function OpportunitiesPage() {
  const [data, setData] = useState<Opportunity[]>([]);
  const [loading, setLoading] = useState(true);
  const [page, setPage] = useState(1);
  const [total, setTotal] = useState(0);
  const [statusFilter, setStatusFilter] = useState("ALL");

  const pageSize = 20;
  const totalPages = Math.ceil(total / pageSize) || 1;

  useEffect(() => {
    async function fetchOpportunities() {
      try {
        setLoading(true);

        const res = await apiClient.get("/opportunities", {
          params: {
            page,
            size: pageSize,
          },
        });

        setData(res.data.items || []);
        setTotal(res.data.total || 0);
      } catch (err) {
        console.error("Failed to fetch opportunities", err);
      } finally {
        setLoading(false);
      }
    }

    fetchOpportunities();
  }, [page]);

  const filteredData = data.filter((item) => {
    if (statusFilter === "ALL") return true;
    return item.status === statusFilter;
  });

  return (
    <AppShell>
      <div className="mb-6">
        <h2 className="text-2xl font-semibold">RFP Opportunities</h2>
        <p className="text-sm text-gray-600">
          Daily inbox of active and relevant RFP opportunities.
        </p>
      </div>

      <div className="flex gap-2 mb-4">
        <button
          onClick={() => setStatusFilter("ALL")}
          className={`px-3 py-1 rounded ${
            statusFilter === "ALL"
              ? "bg-slate-900 text-white"
              : "bg-gray-200"
          }`}
        >
          All
        </button>

        <button
          onClick={() => setStatusFilter("Accepting Bids")}
          className={`px-3 py-1 rounded ${
            statusFilter === "Accepting Bids"
              ? "bg-slate-900 text-white"
              : "bg-gray-200"
          }`}
        >
          Open
        </button>

        <button
          onClick={() => setStatusFilter("Closed")}
          className={`px-3 py-1 rounded ${
            statusFilter === "Closed"
              ? "bg-slate-900 text-white"
              : "bg-gray-200"
          }`}
        >
          Closed
        </button>
      </div>

      <div className="bg-white rounded shadow overflow-hidden">
        {loading ? (
          <p className="p-4">Loading...</p>
        ) : filteredData.length === 0 ? (
          <p className="p-4 text-sm text-gray-600">No opportunities found.</p>
        ) : (
          <table className="w-full text-sm">
            <thead className="bg-gray-50 text-left">
              <tr>
                <th className="p-3">Title</th>
                <th className="p-3">Agency</th>
                <th className="p-3">Portal</th>
                <th className="p-3">Status</th>
                <th className="p-3">Due Date</th>
                <th className="p-3">Score</th>
                <th className="p-3">Source</th>
              </tr>
            </thead>

            <tbody>
              {filteredData.map((item) => {
                const dueDate = new Date(item.due_date);
                const today = new Date();

                const diffDays = Math.ceil(
                  (dueDate.getTime() - today.getTime()) /
                    (1000 * 60 * 60 * 24)
                );

                let dueColor = "text-gray-700";
                if (diffDays <= 3) dueColor = "text-red-600";
                else if (diffDays <= 7) dueColor = "text-yellow-600";

                let scoreColor = "bg-gray-200 text-gray-800";
                if (item.relevance_score >= 80) {
                  scoreColor = "bg-green-100 text-green-700";
                } else if (item.relevance_score >= 50) {
                  scoreColor = "bg-yellow-100 text-yellow-700";
                }

                const firstSeen = item.first_seen_at
                  ? new Date(item.first_seen_at)
                  : null;

                const isNew =
                  firstSeen !== null &&
                  (today.getTime() - firstSeen.getTime()) /
                    (1000 * 60 * 60) <
                    24;

                return (
                  <tr key={item.id} className="border-t hover:bg-gray-50">
                    <td className="p-3 font-medium">
                      {item.title}

                      {isNew && (
                        <span className="ml-2 text-xs px-2 py-1 bg-green-100 text-green-700 rounded">
                          NEW
                        </span>
                      )}
                    </td>

                    <td className="p-3">{item.agency}</td>
                    <td className="p-3">{item.portal}</td>

                    <td className="p-3">
                      <span className="px-2 py-1 text-xs rounded bg-blue-100 text-blue-700">
                        {item.status}
                      </span>
                    </td>

                    <td className={`p-3 ${dueColor}`}>
                      {dueDate.toLocaleDateString()}
                    </td>

                    <td className="p-3">
                      <span className={`px-2 py-1 text-xs rounded ${scoreColor}`}>
                        {item.relevance_score}
                      </span>
                    </td>

                    <td className="p-3">
                      <a
                        href={item.source_url}
                        target="_blank"
                        className="text-blue-600 underline"
                      >
                        View
                      </a>
                    </td>
                  </tr>
                );
              })}
            </tbody>
          </table>
        )}
      </div>

      <div className="flex items-center justify-between mt-4">
        <button
          onClick={() => setPage((prev) => Math.max(prev - 1, 1))}
          disabled={page === 1}
          className="px-3 py-1 bg-gray-200 rounded disabled:opacity-50"
        >
          Previous
        </button>

        <span className="text-sm">
          Page {page} of {totalPages}
        </span>

        <button
          onClick={() =>
            setPage((prev) => (prev < totalPages ? prev + 1 : prev))
          }
          disabled={page >= totalPages}
          className="px-3 py-1 bg-gray-200 rounded disabled:opacity-50"
        >
          Next
        </button>
      </div>
    </AppShell>
  );
}